  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "Topology Overview",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "### MTC Network Core Monitoring\n**Core Router:** `192.168.8.1` via `mktxp` on `localhost:9436`\n\n**Access Point:** `192.168.8.2`\nFallback monitoring is active via blackbox ICMP because no AP exporter was detected on `:9100`.\n\n**Datasource:** `prom-node-local`",
        "mode": "markdown"
      },
      "pluginVersion": "12.0.2",
      "transparent": true
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Router CPU Load",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mktxp_system_cpu_load{job='mikrotik',routerboard_name='mtc-core-router'}",
          "instant": true,
          "editorMode": "code",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
