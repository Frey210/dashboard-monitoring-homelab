    {
      "id": 6,
      "type": "timeseries",
      "title": "WAN RX/TX",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(mktxp_interface_rx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name='ether1'}[$__rate_interval])",
          "editorMode": "code",
          "legendFormat": "WAN RX"
        },
        {
          "refId": "B",
          "expr": "rate(mktxp_interface_tx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name='ether1'}[$__rate_interval])",
          "editorMode": "code",
          "legendFormat": "WAN TX"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "LAN RX/TX",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(mktxp_interface_rx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name=~'ether2|ether3'}[$__rate_interval]))",
          "editorMode": "code",
          "legendFormat": "LAN RX"
        },
        {
          "refId": "B",
          "expr": "sum(rate(mktxp_interface_tx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name=~'ether2|ether3'}[$__rate_interval]))",
          "editorMode": "code",
          "legendFormat": "LAN TX"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "binBps",
          "decimals": 1
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Interface Utilization (%)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (8 * rate(mktxp_interface_tx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name='ether1'}[$__rate_interval])) / clamp_min(mktxp_interface_rate{job='mikrotik',routerboard_name='mtc-core-router',name='ether1'} * 1000000, 1)",
          "editorMode": "code",
          "legendFormat": "WAN TX Util"
        },
        {
          "refId": "B",
          "expr": "100 * (8 * rate(mktxp_interface_rx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name='ether2'}[$__rate_interval])) / clamp_min(mktxp_interface_rate{job='mikrotik',routerboard_name='mtc-core-router',name='ether2'} * 1000000, 1)",
          "editorMode": "code",
          "legendFormat": "LAN ether2 RX Util"
        },
        {
          "refId": "C",
          "expr": "100 * (8 * rate(mktxp_interface_rx_byte_total{job='mikrotik',routerboard_name='mtc-core-router',name='ether3'}[$__rate_interval])) / clamp_min(mktxp_interface_rate{job='mikrotik',routerboard_name='mtc-core-router',name='ether3'} * 1000000, 1)",
          "editorMode": "code",
          "legendFormat": "LAN ether3 RX Util"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
