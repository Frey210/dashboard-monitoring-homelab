      "title": "Router Memory Usage",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - (mktxp_system_free_memory{job='mikrotik',routerboard_name='mtc-core-router'} / mktxp_system_total_memory{job='mikrotik',routerboard_name='mtc-core-router'}))",
          "instant": true,
          "editorMode": "code",
          "legendFormat": ""
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
