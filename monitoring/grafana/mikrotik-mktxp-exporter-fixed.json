    {
      "id": 1,
      "type": "text",
      "title": "Exporter Notes",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "### MKTXP Capability Summary\n- Live exporter metrics use the `mktxp_*` namespace.\n- DHCP lease **count** is available from MKTXP.\n- DHCP lease **IP and hostname** are added through a custom MikroTik API collector.\n- Per-client upload/download traffic is **not available** from the current exporter stack. Aggregate LAN traffic is shown instead.",
        "mode": "markdown"
      },
      "pluginVersion": "12.0.2",
      "transparent": true
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Router CPU Load",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prom-node-local"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "mktxp_system_cpu_load{routerboard_name=\"$node\"}",
          "instant": true,
          "editorMode": "code"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        },
        "overrides": []
      }
    },
